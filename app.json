                  "nl": "Waarschuwing"
                }
              },
              {
                "id": "negative",
                "label": {
                  "en": "Negative",
                  "nl": "Negatief"
                }
              },
              {
                "id": "prohibited",
                "label": {
                  "en": "Prohibited",
                  "nl": "Verbod"
                }
              }
